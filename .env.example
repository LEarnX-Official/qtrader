# Copy this file to `.env` and fill in your own values.
# NEVER commit the real .env — it is gitignored.

# ── CoinMarketCap ───────────────────────────────────────────────────────────
CMC_API_KEY=

# ── Trust Wallet Agent Kit (TWAK) ───────────────────────────────────────────
TWAK_API_KEY=
TWAK_WALLET_ADDRESS=
WALLET_PASSWORD=

# ── Agent wallet (public address is fine; password/keys are NOT here) ────────
AGENT_WALLET_ADDRESS=
WALLET_ADDRESS=

# ── Optional: perp data source ──────────────────────────────────────────────
ASTER_API_KEY=
ASTER_API_SECRET=
ASTER_USER_ADDRESS=

# ── Optional: Telegram alerts ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
